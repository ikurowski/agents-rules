{
  "name": "agent-rules-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,d.ts}\" \"*.{json,mjs,yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,d.ts}\" \"*.{json,mjs,yml,yaml}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "agent:workflow:run": "tsx src/cli/run-agent-workflow-cli.ts",
    "agent:workflow:smoke": "tsx src/cli/run-agent-workflow-cli.ts --prompt \"smoke run\"",
    "contracts:check": "tsx src/cli/check-contracts-cli.ts",
    "skills:validate": "tsx src/cli/validate-skills-cli.ts",
    "docs:map:check": "tsx src/cli/check-docs-map-cli.ts",
    "harness:protocol:check": "tsx src/cli/check-harness-protocol-cli.ts",
    "evals:run": "tsx src/cli/run-evals-cli.ts",
    "idempotency:check": "tsx src/cli/check-idempotency-cli.ts",
    "security:agent": "tsx src/cli/check-security-agent-cli.ts",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run contracts:check && npm run skills:validate && npm run docs:map:check && npm run harness:protocol:check && npm run evals:run && npm run idempotency:check && npm run security:agent"
  },
  "dependencies": {
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-sonarjs": "^3.0.2",
    "eslint-plugin-unicorn": "^56.0.1",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.0.9"
  }
}
