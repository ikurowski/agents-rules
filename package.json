{
  "name": "agent-rules-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,d.ts}\" \"*.{json,mjs,yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,d.ts}\" \"*.{json,mjs,yml,yaml}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "ci": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-sonarjs": "^3.0.2",
    "eslint-plugin-unicorn": "^56.0.1",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.0.9"
  }
}
